{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Skill(.claude/skills/**)",

      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git config --get*)",

      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(echo*)",
      "Bash(pwd)",
      "Bash(which*)",
      "Bash(true)",
      "Bash(false)",

      "Bash(mkdir -p*)",
      "Bash(test*)",
      "Bash(stat*)",
      "Bash(realpath*)",
      "Bash(basename*)",
      "Bash(dirname*)",

      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",
      "Bash(pnpm --version)",
      "Bash(pnpm -v)",
      "Bash(yarn --version)",
      "Bash(yarn -v)",

      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run build*)",
      "Bash(npm run check*)",
      "Bash(npm run dev*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",

      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm tsc*)",
      "Bash(pnpm build*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm check*)",
      "Bash(pnpm check:fix*)",
      "Bash(pnpm run check*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm install*)",
      "Bash(pnpm i)",
      "Bash(pnpm exec*)",

      "Bash(yarn test*)",
      "Bash(yarn lint*)",
      "Bash(yarn typecheck*)",
      "Bash(yarn build*)",
      "Bash(yarn dev*)",
      "Bash(yarn install*)",

      "Bash(npx skills*)",
      "Bash(npx jest*)",
      "Bash(npx vitest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx biome*)",
      "Bash(npx prettier*)",
      "Bash(npx playwright*)",

      "Bash(node_modules/.bin/jest*)",
      "Bash(node_modules/.bin/vitest*)",
      "Bash(node_modules/.bin/tsc*)",
      "Bash(node_modules/.bin/next*)",
      "Bash(node_modules/.bin/eslint*)",
      "Bash(node_modules/.bin/biome*)",
      "Bash(node_modules/.bin/prettier*)",
      "Bash(node_modules/.bin/playwright*)",
      "Bash(./node_modules/.bin/*)",

      "Bash(uv run*)",
      "Bash(uv pip*)",
      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(python -m pip*)",
      "Bash(python --version)",

      "Bash(docker compose ps)",
      "Bash(docker compose logs*)",
      "Bash(docker ps)",
      "Bash(docker logs*)",

      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh api*)",

      "Monitor",
      "BashOutput",
      "KillShell"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/run-with-flags.js dangerous-actions-blocker .claude/hooks/dangerous-actions-blocker.js strict"
          }
        ],
        "description": "Block destructive commands (rm -rf, git push --force, DROP TABLE, etc.)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/run-with-flags.js pre-commit-secrets .claude/hooks/pre-commit-secrets.js standard,strict"
          }
        ],
        "description": "Scan staged files for hardcoded secrets before git commit"
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/run-with-flags.js prompt-injection-detector .claude/hooks/prompt-injection-detector.js standard,strict"
          }
        ],
        "description": "Warn when reading sensitive files that may contain injected instructions"
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/run-with-flags.js prompt-injection-detector .claude/hooks/prompt-injection-detector.js standard,strict"
          }
        ],
        "description": "Warn when fetching URLs with suspicious prompt injection patterns"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/suggest-compact.js"
          }
        ],
        "description": "Suggest /compact at strategic intervals (every 50 then 25 tool calls)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/run-with-flags.js warn-debug-leftovers .claude/hooks/warn-debug-leftovers.js standard,strict"
          }
        ],
        "description": "Warn about console.log/debug in JS/TS files after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-accumulator.js"
          }
        ],
        "description": "Accumulate edited JS/TS/Python paths for batch format+typecheck at Stop"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-accumulator.js"
          }
        ],
        "description": "Accumulate written JS/TS/Python paths for batch format+typecheck at Stop"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/run-with-flags.js session-summary .claude/hooks/session-summary.js standard,strict"
          }
        ],
        "description": "Print session summary (changed files, commits, active tasks) when session ends"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop-format-typecheck.js"
          }
        ],
        "description": "Batch format (Biome/Prettier/ruff) and typecheck all files edited this session"
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\n📋 Claude Agent Workflow — run /caw-status to see all tasks'"
          }
        ]
      }
    ]
  }
}
