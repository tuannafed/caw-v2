# Backlog viewer — environment variables
#
# Copy to .env (gitignored) for local development.
# On Vercel: set the same vars in Dashboard → Project → Settings → Environment Variables.

# ── Auth (client-side localStorage) ──────────────────────────────────
# PUBLIC_ prefix → Vite inlines these into the browser JS bundle at build time.
# This is a low-stakes deterrent, NOT a security boundary — anyone with
# DevTools can read the credentials. Do not use for anything sensitive.
#
# If either is empty, auth is bypassed (safe-deploy mode — the site is
# open until you set these). Useful for first-time deploys.
PUBLIC_AUTH_USER=admin
PUBLIC_AUTH_PASS=change-me

# ── Deploy target ─────────────────────────────────────────────────────
# `vercel` → static prerender for Vercel.
# `local`  → Node SSR with live filesystem access (default for `pnpm dev`).
# Vercel sets this automatically via scripts/build-vercel.mjs.
# DEPLOY_TARGET=vercel

# ── Caw project root ──────────────────────────────────────────────────
# Path to the caw project whose .claude/conductor/tasks/ the viewer reads.
# Required for local dev. On Vercel, build-vercel.mjs computes this from
# the build dir (../../ relative to .claude/backlog-viewer/).
# CAW_PROJECT_ROOT=/path/to/your/project

# ── Dev server ────────────────────────────────────────────────────────
# PORT=4321
