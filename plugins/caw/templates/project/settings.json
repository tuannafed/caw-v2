{
  "// note": "Project .claude/settings.json scaffolded by /caw:setup. Hooks are provided by the caw plugin (hooks.json) — they are NOT duplicated here. This file carries the permission allowlist, env, the caw marketplace registration, and plugin enablement. The marketplace ref tracks 'main' so /plugin marketplace update pulls the latest with no settings edit. Pin ref to a tag/SHA for a frozen install.",
  "extraKnownMarketplaces": {
    "caw": {
      "source": {
        "source": "github",
        "repo": "tuannafed/caw-v2",
        "ref": "main"
      }
    }
  },
  "enabledPlugins": {
    "caw@caw": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "// statusLine note": "Surfaces the harness state (in-progress story · lane · done/total) in the status bar — the DB source of truth, not markdown. Reads harness.db read-only; prints nothing outside a caw project. Remove this block to disable.",
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PLUGIN_ROOT}/statusline/caw-statusline.sh\""
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CAW_HOOK_PROFILE": "standard",
    "// CONTEXT7_API_KEY note": "The Context7 key does NOT go here. A settings.json env is not passed to MCP subprocesses, so a key in this block is silently ignored. Paste the key (free at context7.com/dashboard) literally into the gitignored .mcp.json → mcpServers.context7.env.CONTEXT7_API_KEY, then restart Claude Code. No key = Context7's anonymous tier (free; rate-limited only)."
  },
  "// worktree note": "/caw:code --all runs parallel coders in isolated git worktrees (isolation: worktree). baseRef 'head' makes each worktree fork from the CURRENT branch, not the repo default — so parallel work sees the in-progress branch state. Required for the parallel-coder flow to be correct.",
  "worktree": {
    "baseRef": "head"
  },
  "permissions": {
    "// deny note": "Native deny rules replace the old dangerous-actions-blocker hook. These are prefix-matched (not regex) so they are intentionally broad — Claude Code will refuse any Bash call matching them. Adjust per project if a legitimate command is caught.",
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /)",
      "Bash(sudo rm*)",
      "Bash(mkfs*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -df*)",
      "Bash(git clean -xdf*)",
      "Bash(git branch -D*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*TRUNCATE TABLE*)"
    ],
    "allow": [
      "Read(**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",

      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git config --get*)",

      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(echo*)",
      "Bash(pwd)",
      "Bash(which*)",
      "Bash(true)",
      "Bash(false)",

      "Bash(mkdir -p*)",
      "Bash(test*)",
      "Bash(stat*)",
      "Bash(realpath*)",
      "Bash(basename*)",
      "Bash(dirname*)",

      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",
      "Bash(pnpm --version)",
      "Bash(pnpm -v)",
      "Bash(yarn --version)",
      "Bash(yarn -v)",

      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run build*)",
      "Bash(npm run check*)",
      "Bash(npm run dev*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",

      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm tsc*)",
      "Bash(pnpm build*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm check*)",
      "Bash(pnpm check:fix*)",
      "Bash(pnpm run check*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm install*)",
      "Bash(pnpm i)",
      "Bash(pnpm exec*)",

      "Bash(yarn test*)",
      "Bash(yarn lint*)",
      "Bash(yarn typecheck*)",
      "Bash(yarn build*)",
      "Bash(yarn dev*)",
      "Bash(yarn install*)",

      "Bash(npx jest*)",
      "Bash(npx vitest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx biome*)",
      "Bash(npx prettier*)",
      "Bash(npx playwright*)",

      "Bash(node_modules/.bin/jest*)",
      "Bash(node_modules/.bin/vitest*)",
      "Bash(node_modules/.bin/tsc*)",
      "Bash(node_modules/.bin/next*)",
      "Bash(node_modules/.bin/eslint*)",
      "Bash(node_modules/.bin/biome*)",
      "Bash(node_modules/.bin/prettier*)",
      "Bash(node_modules/.bin/playwright*)",
      "Bash(./node_modules/.bin/*)",

      "Bash(scripts/caw/bin/harness-cli*)",
      "Bash(./scripts/caw/bin/harness-cli*)",
      "Bash(bash scripts/caw/bin/harness-cli*)",

      "Bash(uv run*)",
      "Bash(uv pip*)",
      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(python -m pip*)",
      "Bash(python --version)",

      "Bash(docker compose ps)",
      "Bash(docker compose logs*)",
      "Bash(docker ps)",
      "Bash(docker logs*)",

      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh api*)",

      "Monitor",
      "BashOutput",
      "KillShell"
    ]
  }
}
