{
  "// note": "Project .claude/settings.json scaffolded by /caw:setup. Hooks are provided by the caw plugin (hooks.json) — they are NOT duplicated here. This file carries the permission allowlist, env, the caw marketplace registration, and plugin enablement. The marketplace ref tracks 'main' so /plugin marketplace update pulls the latest with no settings edit. Pin ref to a tag/SHA for a frozen install.",
  "extraKnownMarketplaces": {
    "caw": {
      "source": {
        "source": "github",
        "repo": "tuannafed/caw-v2",
        "ref": "main"
      }
    }
  },
  "enabledPlugins": {
    "caw@caw": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CAW_HOOK_PROFILE": "standard",
    "// CONTEXT7_API_KEY note": "Leave empty to use Context7's shared anonymous tier (low rate limit). For teams/large projects, get a free key at context7.com/dashboard and set it here for your own quota. NEVER commit a real key — set it locally (e.g. in .claude/settings.local.json) instead of committing this value.",
    "CONTEXT7_API_KEY": ""
  },
  "permissions": {
