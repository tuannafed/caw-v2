{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js task-read-gate ${CLAUDE_PLUGIN_ROOT}/hooks/task-read-gate.js strict"
          }
        ],
        "description": "Mark the session as 'task state read' when a harness-cli query runs"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js task-read-gate ${CLAUDE_PLUGIN_ROOT}/hooks/task-read-gate.js strict"
          }
        ],
        "description": "Warn (not block) when editing while a story is in progress but task state wasn't read"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js task-read-gate ${CLAUDE_PLUGIN_ROOT}/hooks/task-read-gate.js strict"
          }
        ],
        "description": "Warn (not block) when writing while a story is in progress but task state wasn't read"
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js prompt-injection-detector ${CLAUDE_PLUGIN_ROOT}/hooks/prompt-injection-detector.js strict"
          }
        ],
        "description": "Warn when reading sensitive files that may contain injected instructions (strict only)"
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js prompt-injection-detector ${CLAUDE_PLUGIN_ROOT}/hooks/prompt-injection-detector.js strict"
          }
        ],
        "description": "Warn when fetching URLs with suspicious prompt injection patterns (strict only)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js post-edit-accumulator ${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-accumulator.js standard,strict"
          }
        ],
        "description": "Accumulate edited JS/TS/Python paths for batch format+typecheck at Stop"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js record-trace ${CLAUDE_PLUGIN_ROOT}/hooks/record-trace.js standard,strict"
          }
        ],
        "description": "Record a harness trace row when a story is in progress and files changed (mechanical observability)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js session-summary ${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.js standard,strict"
          }
        ],
        "description": "Print session summary (changed files, commits, active tasks) when session ends"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/run-with-flags.js stop-format-typecheck ${CLAUDE_PLUGIN_ROOT}/hooks/stop-format-typecheck.js standard,strict"
          }
        ],
        "description": "Batch format (Biome/Prettier/ruff) and typecheck all files edited this session"
      }
    ]
  }
}
